{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FontManifest",
  "description": "Sidecar manifest listing font files stripped from a dehydrated Quill bundle.",
  "type": "object",
  "required": ["version", "files"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version — always 1."
    },
    "files": {
      "type": "object",
      "description": "Maps each stripped font path to its lowercase MD5 hex hash.",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-f0-9]{32}$"
      },
      "propertyNames": {
        "minLength": 1
      }
    }
  }
}
